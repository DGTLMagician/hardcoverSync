# ── Hardcover ──────────────────────────────────────────────────────────────────
# Required. Get your token at: https://hardcover.app/account/api
HARDCOVER_API_TOKEN=your_hardcover_api_token_here
# GraphQL endpoint — do not change unless Hardcover moves it
HARDCOVER_API_URL=https://api.hardcover.app/v1/graphql

# ── Calibre Web Automated (CWA) ────────────────────────────────────────────────
# Absolute path to Calibre's metadata.db on the host (or inside the container).
# Docker example: /books/metadata.db  (if your library volume is mounted at /books)
# Bare-metal example: /opt/calibre/library/metadata.db
CWA_DB_PATH=/books/metadata.db
# Base URL of your CWA instance (used for future API calls / health checks)
CWA_URL=http://localhost:8083
# The CWA user token/username to sync Kobo reading progress from
CWA_USER=

# ── Kobo sync ───────────────────────────────────────────────────────────────────
# Path to your local Kobo database file; used to import read Kobo books into CWA.
KOBO_DB_PATH=/path/to/KoboReader.sqlite
# Optional Kobo API credentials for future remote sync support.
KOBO_API_URL=
KOBO_EMAIL=
KOBO_PASSWORD=

# ── Shelfmark ──────────────────────────────────────────────────────────────────
SHELFMARK_URL=http://localhost:8084
# API key — only required if you enabled authentication in Shelfmark settings
SHELFMARK_API_KEY=
# Preferred download format: epub | mobi | pdf | azw3
SHELFMARK_FORMAT=epub
# ISO 639-1 language code for preferred edition
SHELFMARK_LANGUAGE=en

# ── Sync options ──────────────────────────────────────────────────────────────
# Automatically download missing books via Shelfmark
AUTO_DOWNLOAD=true
# Automatically fix missing books in series by adding them to Want to Read
AUTO_FIX_SERIES=true
# Sync reading progress between services (future feature)
SYNC_READING_PROGRESS=true
# How often to run sync (in minutes)
SYNC_INTERVAL_MINUTES=15

# ── AI Suggestions ────────────────────────────────────────────────────────────
# Base URL for local OpenAI-compatible LLM (e.g., Ollama)
LLM_BASE_URL=http://localhost:11434/v1
# API key for LLM (leave blank if not required)
LLM_API_KEY=
# Model name for LLM
LLM_MODEL=llama3.2:3b

# ── Sync behaviour ─────────────────────────────────────────────────────────────
# How often to run the background sync, in minutes
SYNC_INTERVAL_MINUTES=15
# Comma-separated Hardcover status IDs to include:
#   1 = Want to Read  |  2 = Currently Reading  |  3 = Read  |  5 = Did Not Finish
SYNC_STATUSES=1,2,3
# Set to false to disable Shelfmark download requests (dry-run / library-check only)
AUTO_DOWNLOAD=true
# Push Calibre read data (dates, progress) back to Hardcover
SYNC_READING_PROGRESS=true

# ── Web dashboard ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=5055
# Change this to a long random string before exposing the dashboard externally
SECRET_KEY=change_me_to_something_random

# ── AI Suggestions ──────────────────────────────────────────────────────────────
# Local OpenAI-compatible LLM for generating book recommendations
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama3.2:3b


